# Answer Evaluation System - Environment Configuration
# Copy this file to .env and update the values

# Application Settings
APP_NAME="Subjective Answer Evaluator API"
APP_VERSION="3.0.0"
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000

# Security Settings
# IMPORTANT: Change these in production!
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8501"
API_KEY=""  # Set to enable API key authentication
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=".pdf,.txt,.png,.jpg,.jpeg"

# Model Settings
DEFAULT_MODEL="MiniLM"
SENTENCE_TRANSFORMER_MODELS="all-MiniLM-L6-v2,all-mpnet-base-v2"
CNN_MODEL_PATH="cnn_answer_evaluator.h5"
TOKENIZER_PATH="tokenizer.pkl"

# Scoring Weights (must sum to 1.0)
WEIGHT_SIMILARITY=0.40
WEIGHT_COVERAGE=0.25
WEIGHT_GRAMMAR=0.15
WEIGHT_RELEVANCE=0.20

# OCR Settings
OCR_MIN_TEXT_LENGTH=100
OCR_CONFIDENCE_THRESHOLD=0.6

# Database Settings
DATABASE_URL="sqlite:///./evaluations.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost/evaluations"

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
